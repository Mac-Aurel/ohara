# Groq API key — gratuit sur https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret used to sign JWT session tokens — generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_random_secret

# --- Production only (docker-compose.prod.yml) ---

# Public domain pointed at the VM's IP (e.g. a DuckDNS subdomain). Caddy
# requests a Let's Encrypt certificate for it automatically.
DOMAIN=

# Origin allowed to call api-gateway directly (CORS). Leave unset locally.
CORS_ORIGIN=

# Host interface each service's port is published on. Leave unset locally
# (defaults to 0.0.0.0) — copying this file as-is with BIND_ADDR set would
# make services unreachable from your browser. Set to 127.0.0.1 in prod so
# only Caddy is reachable from outside the VM — every other service stays
# internal-network-only.
BIND_ADDR=
